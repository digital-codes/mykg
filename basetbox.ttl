@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://mykg.local/schema/> .
@prefix data: <http://mykg.local/data/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ==========================================
# 1. THE RDFS SCHEMA (TBox)
# ==========================================

ex:Organization rdf:type rdfs:Class .
ex:Person rdf:type rdfs:Class .
ex:Document rdf:type rdfs:Class .
ex:UAP rdf:type rdfs:Class .
ex:Sighting rdf:type rdfs:Class .


ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:rank rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:title rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:subject rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  rdfs:Literal .
ex:date rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  rdfs:Literal .
ex:document_type rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  rdfs:Literal .
ex:security_classification rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  rdfs:Literal .
ex:code_name rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  rdfs:Literal .
ex:shape rdf:type rdf:Property ;
    rdfs:domain ex:UAP ;
    rdfs:range  rdfs:Literal .
ex:estimated_size rdf:type rdf:Property ;
    rdfs:domain ex:UAP ;
    rdfs:range  rdfs:Literal .
ex:appearance_description rdf:type rdf:Property ;
    rdfs:domain ex:UAP ;
    rdfs:range  rdfs:Literal .
ex:incident_date rdf:type rdf:Property ;
    rdfs:domain ex:Sighting ;
    rdfs:range  rdfs:Literal .
ex:incident_location rdf:type rdf:Property ;
    rdfs:domain ex:Sighting ;
    rdfs:range  rdfs:Literal .
ex:weather_conditions rdf:type rdf:Property ;
    rdfs:domain ex:Sighting ;
    rdfs:range  rdfs:Literal .

ex:member_of rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Organization .
ex:authored_by rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  ex:Person .
ex:issued_by rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  ex:Organization .
ex:sent_to rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  ex:Organization .
ex:describes_sighting rdf:type rdf:Property ;
    rdfs:domain ex:Document ;
    rdfs:range  ex:Sighting .
ex:witnessed_by rdf:type rdf:Property ;
    rdfs:domain ex:Sighting ;
    rdfs:range  ex:Person .
ex:identifies_uap rdf:type rdf:Property ;
    rdfs:domain ex:Sighting ;
    rdfs:range  ex:UAP .
