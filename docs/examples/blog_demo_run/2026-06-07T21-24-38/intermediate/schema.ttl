@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://mykg.local/schema/> .
@prefix data: <http://mykg.local/data/> .

# ==========================================
# 1. THE RDFS SCHEMA (TBox)
# ==========================================

ex:Person rdf:type rdfs:Class .
ex:Organization rdf:type rdfs:Class .
ex:Team rdf:type rdfs:Class .
ex:Project rdf:type rdfs:Class .
ex:Technology rdf:type rdfs:Class .
ex:Location rdf:type rdfs:Class .

ex:Team rdfs:subClassOf ex:Organization .

ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:title rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:email rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:education rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
ex:industry rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
ex:headquarters rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
ex:focus rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  rdfs:Literal .
ex:member_count rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:status rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:target_date rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:budget rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Technology ;
    rdfs:range  rdfs:Literal .
ex:category rdf:type rdf:Property ;
    rdfs:domain ex:Technology ;
    rdfs:range  rdfs:Literal .
ex:vendor rdf:type rdf:Property ;
    rdfs:domain ex:Technology ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Location ;
    rdfs:range  rdfs:Literal .
ex:country rdf:type rdf:Property ;
    rdfs:domain ex:Location ;
    rdfs:range  rdfs:Literal .
ex:region rdf:type rdf:Property ;
    rdfs:domain ex:Location ;
    rdfs:range  rdfs:Literal .

ex:works_at rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Organization .
ex:member_of rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Team .
ex:manages rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Team .
ex:reports_to rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Person .
ex:contributes_to rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Project .
ex:owns_project rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  ex:Project .
ex:depends_on rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  ex:Project .
ex:uses_technology rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  ex:Technology .
ex:partners_with rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Organization .
ex:provides_technology rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Technology .
ex:located_in rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Location .
ex:part_of rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  ex:Organization .


