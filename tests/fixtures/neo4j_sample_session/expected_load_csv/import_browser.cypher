// Generated by mykg emit_load_csv. Do not edit by hand.

// 1. Constraint
CREATE CONSTRAINT _mykgnode_id_unique IF NOT EXISTS
FOR (n:_MykgNode) REQUIRE n.id IS UNIQUE;

// 2. Nodes — one block per label

:auto LOAD CSV WITH HEADERS FROM 'file:/nodes_Organization.csv' AS row
CALL {
  WITH row
  MERGE (n:_MykgNode {id: row.id})
  SET n:Organization
  SET
      n._node_confidence = CASE WHEN row._node_confidence = '' THEN null ELSE toFloat(row._node_confidence) END,
      n._parents = CASE WHEN row._parents = '' THEN [] ELSE split(row._parents, ';') END,
      n._source_files = CASE WHEN row._source_files = '' THEN [] ELSE split(row._source_files, ';') END,
      n.industry = CASE WHEN row.industry = '' THEN null ELSE row.industry END,
      n.industry_confidence = CASE WHEN row.industry_confidence = '' THEN null ELSE toFloat(row.industry_confidence) END,
      n.name = CASE WHEN row.name = '' THEN null ELSE row.name END,
      n.name_confidence = CASE WHEN row.name_confidence = '' THEN null ELSE toFloat(row.name_confidence) END
} IN TRANSACTIONS OF 1000 ROWS;

