// 3. Edges — one block per rel-type

:auto LOAD CSV WITH HEADERS FROM 'file:/relationships_KNOWS.csv' AS row
CALL {
  WITH row
  MATCH (a:_MykgNode {id: row.from})
  MATCH (b:_MykgNode {id: row.to})
  MERGE (a)-[r:KNOWS]->(b)
  SET
      r.confidence = CASE WHEN row.confidence = '' THEN null ELSE toFloat(row.confidence) END,
      r.method = CASE WHEN row.method = '' THEN null ELSE row.method END,
      r.source_files = CASE WHEN row.source_files = '' THEN [] ELSE split(row.source_files, ';') END
} IN TRANSACTIONS OF 1000 ROWS;

